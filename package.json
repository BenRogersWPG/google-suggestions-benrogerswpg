{
  "version": "3.1.0",
  "license": "MIT",
  "main": "dist/index.js",
  "typings": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=12"
  },
  "scripts": {
    "start": "tsdx watch",
    "build": "tsdx build",
    "test": "tsdx test --passWithNoTests",
    "lint": "tsdx lint",
    "prepare": "tsdx build",
    "size": "size-limit",
    "analyze": "size-limit --why"
  },
  "husky": {
    "hooks": {
      "pre-commit": "tsdx lint"
    }
  },
  "prettier": {
    "printWidth": 80,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5"
  },
  "name": "google-suggestions-benrogerswpg",
  "author": "Yuvraj Seegolam",
  "repository": "BenRogersWPG/google-suggestions-benrogerswpg",
  "description": "Get Google Search Suggestions for a given query",
  "keywords": [
    "google",
    "search",
    "suggestions",
    "autocomplete",
    "suggest"
  ],
  "module": "dist/google-suggestions-benrogerswpg.esm.js",
  "size-limit": [
    {
      "path": "dist/google-suggestions-benrogerswpg.cjs.production.min.js",
      "limit": "10 KB"
    },
    {
      "path": "dist/google-suggestions-benrogerswpg.esm.js",
      "limit": "10 KB"
    }
  ],
  "devDependencies": {
    "@size-limit/preset-small-lib": "^12.1.0",
    "husky": "^9.1.7",
    "size-limit": "^12.1.0",
    "tsdx": "^2.0.0",
    "tslib": "^2.4.1",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "axios": "^1.18.1"
  }
}